&CONTROL
title dbh-11
ml_ncpu       1
qc_ncpu       1
gl_seed       1
jobtype       md
qm            nequip

&Molecule
ci	 2
spin     0
coupling 1 2

&MD
ninitcond 5000
method wigner
format molden
step 2000
size 20.67
sfhp fssh
nactype nac
adjust 2
phasecheck 1
root 2
thermo off
silent 1
verbose 0
direct 2000
buffer 0
record 1
phasecheck 1
checkpoint 1

&NEQUIP
modeldir dbh-11.nequip.pth
gpu         1
nac_unit    au
eg_unit     au

&NEQUIP_EG
model_type    eg
model_path dbh-11.nequip.pth
gpu           1
natom         15

&NEQUIP_NAC
model_type    nac
model_path dbh-11.nequip.pth
gpu           1
natom         15



